# Configuration de l'application PéléVTT
# Copier ce fichier vers .env et ajuster les valeurs

# Port de l'application
APP_PORT=62000

# Contexte de la route (instance dédiée)
ROUTE_NAME=Route 62
ROUTE_SLUG=route62

# Redis configuration
REDIS_URL=redis://localhost:6379
REDIS_ENABLED=true
REDIS_CHANNEL=passages:route62

# Clé d'administration pour API
# Générer avec: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_KEY=0d803d527bf79cb747aeb51c42c15ad017e0d9f7fb3cbb7b6afa90b952e4fb4f

# CORS - Origines autorisées (séparées par virgules)
ALLOWED_ORIGINS=https://api.pelevtt.cloud:443,http://pelevtt.cloud

# ========================================
# CONFIGURATION AUTHENTIFICATION
# ========================================

# Hash bcrypt du mot de passe de configuration
# Par défaut: 'aaqq' (À CHANGER EN PRODUCTION!)
# Générer un nouveau hash avec: python3 generate_password_hash.py votre_mot_de_passe
CONFIG_PASSWORD_HASH=$2b$12$LQv3c1yqBWVHxkd0LHAkCOYz6TtxMeshqdh.h5CjQqgPJ0d8/Qg.m

# Secret pour les sessions (généré automatiquement si non défini)
# Générer avec: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# Durée de validité des sessions en heures (défaut: 24)
SESSION_DURATION_HOURS=24
