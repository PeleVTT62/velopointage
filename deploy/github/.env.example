# Configuration minimale pour deployment GitHub (1 route)
# Copier vers .env.github-minimal

# Port HTTP publie
APP_PORT=62000

# Route par defaut (a adapter)
ROUTE_NAME=Route 00
ROUTE_SLUG=route00

# URL publique de votre instance (a personnaliser)
ALLOWED_ORIGINS=https://route00.example.org

# Cle admin API (peut rester ainsi pour un test local, a changer en production)
ADMIN_KEY=change-me-admin-key

# Mot de passe admin interface configuration (hash bcrypt)
# Hash par defaut du mot de passe: "pelevtt"
CONFIG_PASSWORD_HASH=$$2y$$12$$Fg4/0WpGp9YVnTdy9x9nBOlodGvzDE600RrLFoSGQ.HAefgkTsFo2

# Secret session (a changer en production)
SESSION_SECRET=change-me-session-secret
SESSION_DURATION_HOURS=24
